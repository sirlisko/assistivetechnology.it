---
interface Props {
	prev?: {
		href: string;
		title: string;
	};
	next?: {
		href: string;
		title: string;
	};
}

const { prev, next } = Astro.props;
---

<nav role="navigation" aria-label="Navigazione capitoli">
  <ul>
    <li class="prev">
      {
        prev && (
          <a
            href={prev.href}
            rel="prev"
            aria-label={`Capitolo precedente: ${prev.title}`}
          >
            <span aria-hidden="true">&lt;&lt;</span> {prev.title}
          </a>
        )
      }
    </li>
    <li class="index">
      <a href="/" aria-label="Torna all'indice principale">Indice</a>
    </li>
    <li class="next">
      {
        next && (
          <a
            href={next.href}
            rel="next"
            aria-label={`Capitolo successivo: ${next.title}`}
          >
            {next.title} <span aria-hidden="true">&gt;&gt;</span>
          </a>
        )
      }
    </li>
  </ul>
</nav>

<style>
  nav {
    color: #aaa;
    max-width: 850px;
    width: 100%;
  }
  nav ul {
    list-style-type: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
  }
  nav li.prev {
    text-align: right;
  }
</style>
