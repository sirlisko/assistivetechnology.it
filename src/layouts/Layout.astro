---
import Navigation from "../components/Navigation.astro";

interface Props {
	description: string;
	keywords: string;
	title: string;
	section?: string;
	prev?: {
		href: string;
		title: string;
	};
	next?: {
		href: string;
		title: string;
	};
	hideNavigation?: boolean;
}
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href.replace(
	/\/+$/,
	"",
);
const { description, keywords, title, prev, next, hideNavigation, section } =
	Astro.props;

const titleFull = `${title} - Assistive Technology - Informatizzando la Disabilità`;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="Luca Lischetti" />
    <meta name="theme-color" content="#005fcc" />
    <link type="text/plain" rel="author" href="/humans.txt" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:image" content="https://assistivetechnology.it/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Assistive Technology - Informatizzando la Disabilità" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://assistivetechnology.it/og-image.png" />
    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Assistive Technology - Informatizzando la Disabilità",
        "description": "Risorse sulla tecnologia assistiva e accessibilità web - Tesi di Luca Lischetti",
        "url": "https://assistivetechnology.it",
        "author": {
          "@type": "Person",
          "name": "Luca Lischetti",
          "url": "https://sirlisko.com"
        },
        "inLanguage": "it-IT",
        "license": "https://creativecommons.org/licenses/by-nc-sa/4.0/deed.it",
        "dateCreated": "2010-03-14",
        "dateModified": "2012-06-01",
        "keywords": "assistive technology, accessibilità web, disabilità, tecnologie assistive, W3C, WAI, WCAG"
      }
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": titleFull,
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Luca Lischetti",
        "url": "https://sirlisko.com"
      },
      "datePublished": "2010-03-14",
      "dateModified": "2012-06-01",
      "isPartOf": {
        "@type": "Book",
        "name": "Assistive Technology - Informatizzando la Disabilità"
      },
      "articleSection": section || null,
      "inLanguage": "it-IT",
      "url": canonicalURL
    })}>
    </script>
    <title>{titleFull}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Vai al contenuto principale</a>
    {!hideNavigation && <Navigation prev={prev} next={next} />}
    <main id="main" role="main" lang="it">
      <slot />
    </main>
    {!hideNavigation && <Navigation prev={prev} next={next} />}
    <footer role="contentinfo">
      <p>
        &copy; <a href="https://sirlisko.com" rel="noopener">Luca Lischetti</a> (<a
          href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.it" rel="noopener"
          >licenza</a
        >), scritto Gennaio - Marzo 2010, ultima modifica Giugno 2012.
      </p>
      <p>
        Codice del sito disponibile su Github <a
          href="https://github.com/sirlisko/assistivetechnology.it" rel="noopener"
          >https://github.com/sirlisko/assistivetechnology.it</a
        >.
      </p>
    </footer>
  </body>
</html>
